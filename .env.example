DATABASE_URL=postgresql://postgres:postgres@localhost:5432/afm_flights
DATABASE_URL_DIRECT=
DATABASE_SSL=false
SUPABASE_PROJECT_REF=

# Auth (Sprint 3 - NextAuth v5)
# Generate con: openssl rand -base64 32
AUTH_SECRET=change-me-in-production
AUTH_SEED_EMAIL=admin@aeroadmin.local
AUTH_SEED_PASSWORD=ChangeMe123!

# Sprint B — F1.11: nombre del operador que aparece en el header del
# reporte PDF de parcela. Default sensato (se sobreescribe en prod via
# el dashboard de env vars de Vercel o el .env real).
OPERATOR_NAME=AeroAdmin Cañero
OPERATOR_REGION=Valle del Cauca, Colombia

# Variantes `NEXT_PUBLIC_*` que se exponen al cliente (bundle del
# browser). Se usan en el CSV de fumigaciones para que el operador
# vea el header del operador al abrir el archivo en Excel sin
# internet. Mismo default que la version server-only.
NEXT_PUBLIC_OPERATOR_NAME=AeroAdmin Cañero
NEXT_PUBLIC_OPERATOR_REGION=Valle del Cauca, Colombia
